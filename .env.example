# .env.example — Plantilla de variables de entorno
# Copia este archivo a .env y reemplaza los valores con tus credenciales
# 
# NOTA: Este archivo es una referencia. Los defaults de application.properties
# ya incluyen fallbacks para desarrollo local.

# ── Global (todos los servicios) ───────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev

# ── state-service (Redis) ──────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── ui-service URLs internas ───────────────────────────────────────────
STATE_SERVICE_URL=http://localhost:8081
AI_SERVICE_URL=http://localhost:8083
BASE_URL=http://localhost:8082

# ── ui-service PostgreSQL (Aiven) ──────────────────────────────────────
# En desarrollo, usa H2 (ya configurado). En producción, obtén de Aiven.
DATABASE_URL=jdbc:postgresql://localhost:5432/slidehub?sslmode=disable
DB_DRIVER=org.postgresql.Driver
JPA_DIALECT=org.hibernate.dialect.PostgreSQLDialect

# ── ui-service OAuth2 GitHub ───────────────────────────────────────────
# Registra en https://github.com/settings/developers → OAuth Apps → New
# Callback URL (dev): http://localhost:8080/login/oauth2/code/github
# Callback URL (prod): https://slide.lat/login/oauth2/code/github
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ── ui-service OAuth2 Google ───────────────────────────────────────────
# Registra en https://console.cloud.google.com → APIs & Services → Credentials
# Callback URL (dev): http://localhost:8080/login/oauth2/code/google
# Callback URL (prod): https://slide.lat/login/oauth2/code/google
# Scopes: openid profile email https://www.googleapis.com/auth/drive.readonly
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── ui-service Resend (Email) ──────────────────────────────────────────
# Genera en https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key

# ── ui-service Amazon S3 ───────────────────────────────────────────────
# Crea IAM user en AWS con AmazonS3FullAccess
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG...
AWS_S3_BUCKET=slidehub-assets
AWS_REGION=us-east-1

# ── ai-service MongoDB ─────────────────────────────────────────────────
# Local: mongodb://localhost:27017/slidehub
# MongoDB Atlas: mongodb+srv://user:password@cluster.mongodb.net/slidehub?retryWrites=true
MONGODB_URI=mongodb://localhost:27017/slidehub

# ── ai-service Gemini API ─────────────────────────────────────────────
# Genera en https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSy...

# ── ai-service Groq API ───────────────────────────────────────────────
# Genera en https://console.groq.com/keys
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama3-8b-8192
